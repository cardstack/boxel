#!/bin/sh
#MISE description="Start base realm server only"
#MISE depends=["infra:ensure-dev-cert", "infra:ensure-pg", "infra:wait-for-prerender"]
#MISE dir="packages/realm-server"

# Treat SIGTERM/SIGINT as a clean shutdown so mise / run-p don't report
# 143-on-Ctrl-C as a task failure. See mise-tasks/services/worker for the
# rationale.
trap 'exit 0' INT TERM

if [ -z "$MATRIX_REGISTRATION_SHARED_SECRET" ]; then
  MATRIX_REGISTRATION_SHARED_SECRET=$(node ./scripts/matrix-registration-secret.ts)
  export MATRIX_REGISTRATION_SHARED_SECRET
fi

NODE_ENV=development \
  NODE_NO_WARNINGS=1 \
  PGPORT="${PGPORT}" \
  PGDATABASE=boxel_base \
  REALM_SERVER_SECRET_SEED="mum's the word" \
  REALM_SECRET_SEED="shhh! it's a secret" \
  GRAFANA_SECRET="shhh! it's a secret" \
  AI_BOT_DELEGATION_SECRET="shhh! it's a secret" \
  MATRIX_URL="${MATRIX_URL_VAL}" \
  REALM_SERVER_MATRIX_USERNAME=realm_server \
  node main.ts \
  --port=4201 \
  --matrixURL="${MATRIX_URL_VAL}" \
  --realmsRootPath='./realms/localhost_4201_base' \
  --prerendererUrl="${PRERENDER_MGR_URL}" \
  --migrateDB \
  $1 \
  \
  --path='../base' \
  --username='base_realm' \
  --fromUrl='@cardstack/base/' \
  --toUrl='https://localhost:4201/base/' \
  \
  --fromUrl='https://cardstack.com/base/' \
  --toUrl='https://localhost:4201/base/'
