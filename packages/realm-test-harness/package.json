{
  "name": "@cardstack/realm-test-harness",
  "private": true,
  "version": "1.0.0",
  "license": "MIT",
  "description": "Spin up an isolated boxel realm-server stack (postgres + prerender + worker + realm-server) against a fixture realm directory. Used by integration tests, benchmarks, and CLI dev tools that need a hermetic realm.",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json",
    "./*": "./src/*.ts"
  },
  "scripts": {
    "lint": "concurrently \"pnpm:lint:*(!fix)\" --names \"lint:\"",
    "lint:fix": "concurrently \"pnpm:lint:*:fix\" --names \"fix:\"",
    "lint:js": "eslint . --report-unused-disable-directives --cache",
    "lint:js:fix": "eslint . --report-unused-disable-directives --fix",
    "lint:types": "tsc --noEmit"
  },
  "devDependencies": {
    "@cardstack/local-types": "workspace:*",
    "@cardstack/logger": "^0.2.1",
    "@cardstack/runtime-common": "workspace:*",
    "@types/fs-extra": "catalog:",
    "@types/jsonwebtoken": "catalog:",
    "@types/node": "catalog:",
    "@types/pg": "catalog:",
    "concurrently": "catalog:",
    "eslint": "catalog:",
    "fs-extra": "catalog:",
    "jsonwebtoken": "catalog:",
    "pg": "catalog:",
    "puppeteer": "^25.0.2",
    "ts-node": "^10.9.1",
    "typescript": "catalog:"
  },
  "volta": {
    "extends": "../../package.json"
  }
}
