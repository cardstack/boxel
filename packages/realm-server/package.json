{
  "name": "@cardstack/realm-server",
  "version": "0.0.0",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "@aws-crypto/sha256-js": "catalog:",
    "@cardstack/billing": "workspace:*",
    "@cardstack/boxel-icons": "workspace:*",
