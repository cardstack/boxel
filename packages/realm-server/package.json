    "@cardstack/local-types": "workspace:*",
    "@cardstack/postgres": "workspace:*",
    "@cardstack/runtime-common": "workspace:*",
    "@glint/ember-tsc": "1.5.0",
    "@koa/cors": "catalog:",
    "@koa/router": "catalog:",
    "@octokit/rest": "catalog:",
    "@sentry/node": "catalog:",
    "@types/archiver": "catalog:",
