{
  "compilerOptions": {
    "target": "es2023",
    "lib": ["es2023", "dom"],
    "allowJs": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "allowSyntheticDefaultImports": true,
    "allowImportingTsExtensions": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "strictNullChecks": true,
    "strictPropertyInitialization": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noEmitOnError": false,
    "noEmit": true,
    "inlineSourceMap": true,
    "inlineSources": true,
    "baseUrl": ".",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "strict": true,
    "paths": {
      "@cardstack/base/*": [
        "../base/*.gts",
        "../base/*.ts",
        "../base/*.d.ts",
        "../base/*"
      ],
      "https://cardstack.com/base/*": [
        "../base/*.gts",
        "../base/*.ts",
        "../base/*.d.ts",
        "../base/*"
      ],
      "@cardstack/boxel-ui": ["../boxel-ui/addon"],
      "@cardstack/boxel-ui/*": ["../boxel-ui/addon/*"],
      "@cardstack/runtime-common": ["../runtime-common"],
      "@cardstack/runtime-common/*": ["../runtime-common/*"],
      "@cardstack/postgres": ["../postgres"],
      "@cardstack/postgres/*": ["../postgres/*"]
    },
    "types": ["@cardstack/local-types", "qunit"]
  },
  "include": [
    "../base/**/*",
    "../runtime-common/**/*",
    "../postgres/**/*",
    "./**/*"
  ],
  "exclude": ["../base/**/__boxel/**"]
}
