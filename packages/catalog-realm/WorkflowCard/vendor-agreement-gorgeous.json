        {
          "initials": "CP",
          "author": "@ChesterP",
          "sentAt": "Jan 6, 9:08 AM",
          "text": "Hi Daisy, I hope you had a relaxing weekend after Friday's extravaganza. You did a lovely job with the Aceters' anniversary party! As discussed, we would like to offer you a preferred vendor agreement. Have you had a chance to look over the terms?",
          "tone": "captain",
          "isBot": ""
        },
        {
          "initials": "DC",
          "author": "@DaisyChain",
          "sentAt": "Jan 6, 9:21 AM",
          "text": "Hi Chester, I did, thanks! I really enjoyed working with your team, and the location is amazing. The terms look good, I'm ready to sign when you are.",
          "tone": "advisor",
          "isBot": ""
        },
        {
          "initials": "CP",
          "author": "@ChesterP",
          "sentAt": "Jan 6, 9:45 AM",
          "text": "That's great to hear. Here's the finalized contract for you to sign. We look forward to working with you on a regular basis.",
          "tone": "captain",
          "isBot": ""
        },
        {
          "initials": "DC",
          "author": "@DaisyChain",
          "sentAt": "Jan 6, 10:35 AM",
          "text": "I look forward to working with you too! Here's the signed contract.",
          "tone": "advisor",
          "isBot": ""
        },
        {
          "initials": "CP",
          "author": "@ChesterP",
          "sentAt": "Jan 6, 10:52 AM",
          "text": "Thanks for signing! The next step is your profile that we will add to our website. Here's a template I would ask you to fill out. Please include a high-quality photo in addition to your logo.",
          "tone": "captain",
          "isBot": ""
        },
        {
          "initials": "DC",
          "author": "@DaisyChain",
          "sentAt": "Jan 6, 11:24 AM",
          "text": "Here's my profile card for your website. Please let me know if you need anything else. Can't wait to start planning the next event at this beautiful venue!",
          "tone": "advisor",
          "isBot": ""
        },
        {
          "initials": "CP",
          "author": "@ChesterP",
          "sentAt": "Jan 6, 12:08 PM",
          "text": "Thanks for sending your profile so quickly. I've added you to our website. Check it out: gorgeoushotel.com/eventplanning",
          "tone": "captain",
          "isBot": ""
        }
