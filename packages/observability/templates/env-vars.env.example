# Example environment variables for grafanactl + the local docker-compose.
# Copy to env-vars.env (gitignored) and fill in real values for your shell:
#
#   cp templates/env-vars.env.example env-vars.env
#   set -a; source env-vars.env; set +a
#
# Filled out further in CS-10913 (the staging/production grafanactl context wiring).

# ──────────────────────────────────────────────────────────────────────────
# grafanactl auth — used by `grafanactl resources push` / `pull` from your
# laptop. Per https://grafana.com/docs/grafana/latest/cli/grafanactl/.
# ──────────────────────────────────────────────────────────────────────────

# For local: leave GRAFANA_TOKEN empty for now. Once CS-10913 wires the local
# context, the script creates a service account in the local Grafana and
# stores the token here automatically.
# GRAFANA_TOKEN=

# Local Grafana served by docker-compose on port 3001.
# GRAFANA_SERVER=http://localhost:3001
# GRAFANA_ORG_ID=1

# ──────────────────────────────────────────────────────────────────────────
# Local data-source overrides — the local Grafana's postgres data source
# points at the dev's boxel-pg via host.docker.internal. Override these only
# if your local Postgres setup differs.
# ──────────────────────────────────────────────────────────────────────────

# BOXEL_DB_HOST=host.docker.internal
# BOXEL_DB_PORT=5435
# BOXEL_DB_USER=postgres
# BOXEL_DB_NAME=boxel
