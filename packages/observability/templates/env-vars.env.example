# Example environment variables for grafanactl + local docker-compose.
# Copy to env-vars.env (gitignored) and fill in real values for your shell.
# Filled out for real in CS-10912 / CS-10913.

# grafanactl auth (per https://grafana.com/docs/grafana/latest/cli/grafanactl/)
# GRAFANA_TOKEN=
# GRAFANA_SERVER=http://localhost:3001
# GRAFANA_ORG_ID=1

# Local Postgres (the realm-server DB) — used by the postgres data source
# BOXEL_DB_HOST=host.docker.internal
# BOXEL_DB_USER=postgres
# BOXEL_DB_NAME=boxel
