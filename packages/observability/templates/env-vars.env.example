# Example environment variables for grafanactl.
# Most local workflows do NOT need to set these — `./scripts/apply.sh` (and
# friends) source `./scripts/grafanactl-env.sh` automatically based on the
# `--env` flag. This template is here for the rare ad-hoc invocation of
# `grafanactl` directly without going through the wrapper scripts.
#
# Copy to env-vars.env (gitignored) and source it:
#
#   cp templates/env-vars.env.example env-vars.env
#   set -a; source env-vars.env; set +a

# ──────────────────────────────────────────────────────────────────────────
# grafanactl auth
# ──────────────────────────────────────────────────────────────────────────
# Per https://grafana.com/docs/grafana/latest/cli/grafanactl/.
#
# For LOCAL development, the docker-compose Grafana uses admin/admin basic
# auth — wired into the local context via grafanactl/config.yaml. Leave
# GRAFANA_TOKEN unset.
#
# For STAGING/PRODUCTION, source the helper instead of setting GRAFANA_TOKEN
# manually:
#
#   source ./scripts/grafanactl-env.sh staging
#
# The helper fetches the token from SSM `/<env>/grafana/grafanactl_token`
# and exports it. If you really want to set things by hand:

# GRAFANA_TOKEN=
# GRAFANA_SERVER=http://localhost:3001
# GRAFANA_ORG_ID=1

# ──────────────────────────────────────────────────────────────────────────
# Local data-source overrides — the local Grafana's postgres data source
# points at the dev's boxel-pg via host.docker.internal. Override these only
# if your local Postgres setup differs.
# ──────────────────────────────────────────────────────────────────────────

# BOXEL_DB_HOST=host.docker.internal
# BOXEL_DB_PORT=5435
# BOXEL_DB_USER=postgres
# BOXEL_DB_NAME=boxel
