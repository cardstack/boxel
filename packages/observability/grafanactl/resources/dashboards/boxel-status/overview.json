        "pluginVersion": "12.4.3",
        "targets": [
          {
            "datasource": { "type": "grafana-postgresql-datasource", "uid": "cef5v5sl9k7i8f" },
            "editorMode": "code", "format": "time_series", "rawQuery": true,
            "rawSql": "SELECT $__timeGroupAlias(j.created_at, '30s'), COUNT(*) AS arrived FROM jobs j WHERE j.job_type IN ('from-scratch-index','incremental-index','full-reindex') AND $__timeFilter(j.created_at) GROUP BY 1 ORDER BY 1;",
            "refId": "A"
          },
          {
            "datasource": { "type": "grafana-postgresql-datasource", "uid": "cef5v5sl9k7i8f" },
            "editorMode": "code", "format": "time_series", "rawQuery": true,
            "rawSql": "SELECT $__timeGroupAlias(jr.created_at, '30s'), COUNT(*) AS started FROM job_reservations jr JOIN jobs j ON j.id = jr.job_id WHERE j.job_type IN ('from-scratch-index','incremental-index','full-reindex') AND $__timeFilter(jr.created_at) GROUP BY 1 ORDER BY 1;",
            "refId": "B"
          },
          {
            "datasource": { "type": "grafana-postgresql-datasource", "uid": "cef5v5sl9k7i8f" },
            "editorMode": "code", "format": "time_series", "rawQuery": true,
            "rawSql": "SELECT $__timeGroupAlias(j.finished_at, '30s'), COUNT(*) AS completed FROM jobs j WHERE j.job_type IN ('from-scratch-index','incremental-index','full-reindex') AND j.finished_at IS NOT NULL AND $__timeFilter(j.finished_at) GROUP BY 1 ORDER BY 1;",
            "refId": "C"
          }
        ],
        "title": "Indexing throughput",
        "type": "timeseries"
      },
