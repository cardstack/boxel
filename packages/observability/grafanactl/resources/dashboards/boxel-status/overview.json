          "editorMode": "code", "format": "table", "rawQuery": true,
          "rawSql": "SELECT COUNT(*) AS in_flight FROM jobs j JOIN job_reservations jr ON j.id = jr.job_id AND jr.completed_at IS NULL AND jr.locked_until > NOW() WHERE j.finished_at IS NULL AND j.job_type IN ('from-scratch-index','incremental-index','full-reindex');",
          "refId": "A"
        }],
        "title": "In-flight",
        "type": "stat"
      },
      {
        "datasource": { "type": "grafana-postgresql-datasource", "uid": "cef5v5sl9k7i8f" },
        "description": "Age of the oldest pending indexing job. Yellow at 1 minute, red at 5 minutes.",
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "links": [{ "title": "Open Indexing dashboard", "url": "/d/aetquzjcf2znke", "targetBlank": false }],
            "mappings": [],
            "thresholds": {
              "mode": "absolute",
              "steps": [
