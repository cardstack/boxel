        "pluginVersion": "12.4.3",
        "targets": [{
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "cef5v5sl9k7i8f" },
          "editorMode": "code", "format": "table", "rawQuery": true,
          "rawSql": "SELECT EXTRACT(EPOCH FROM (NOW() - MIN(j.created_at))) AS oldest_pending_seconds FROM jobs j LEFT JOIN job_reservations jr ON j.id = jr.job_id AND jr.completed_at IS NULL AND jr.locked_until > NOW() WHERE j.status = 'unfulfilled' AND j.job_type IN ('from-scratch-index','incremental-index','full-reindex') AND jr.id IS NULL;",
          "refId": "A"
        }],
        "title": "Oldest Pending",
        "type": "stat"
      },
