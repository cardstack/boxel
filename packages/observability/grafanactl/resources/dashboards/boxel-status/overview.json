        "datasource": { "type": "grafana-postgresql-datasource", "uid": "cef5v5sl9k7i8f" },
        "description": "Indexing jobs (from-scratch-index, incremental-index, full-reindex) waiting on a worker. Click to open Indexing dashboard.",
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "links": [{ "title": "Open Indexing dashboard", "url": "/d/aetquzjcf2znke", "targetBlank": false }],
            "mappings": [],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 5 },
                { "color": "red", "value": 50 }
              ]
            }
          }
        },
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 12 },
        "id": 7,
        "options": {
          "colorMode": "value",
          "graphMode": "none",
          "justifyMode": "auto",
          "orientation": "horizontal",
          "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
          "textMode": "auto"
        },
        "pluginVersion": "12.4.3",
        "targets": [{
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "cef5v5sl9k7i8f" },
          "editorMode": "code", "format": "table", "rawQuery": true,
          "rawSql": "SELECT COUNT(*) AS pending FROM jobs j LEFT JOIN job_reservations jr ON j.id = jr.job_id AND jr.completed_at IS NULL AND jr.locked_until > NOW() WHERE j.status = 'unfulfilled' AND j.job_type IN ('from-scratch-index','incremental-index','full-reindex') AND jr.id IS NULL;",
          "refId": "A"
        }],
        "title": "Pending Indexing Jobs",
        "type": "stat"
      },
