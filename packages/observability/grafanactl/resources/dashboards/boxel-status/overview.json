          }
        },
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 12 },
        "id": 9,
        "options": {
          "colorMode": "value",
          "graphMode": "none",
          "justifyMode": "auto",
          "orientation": "horizontal",
          "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
          "textMode": "auto"
