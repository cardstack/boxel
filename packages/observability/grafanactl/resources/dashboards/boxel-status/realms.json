        "targets": [
          {
            "datasource": {
              "type": "grafana-postgresql-datasource",
              "uid": "cef5v5sl9k7i8f"
            },
            "editorMode": "code",
            "format": "table",
            "rawQuery": true,
            "rawSql": "SELECT\n  j.id::text || '.' || COALESCE(jr.id::text, '-') AS job_id,\n  j.id::text AS job_id_short,\n  j.job_type,\n  j.status::text AS status,\n  COALESCE(jr.created_at, j.created_at) AS started_at,\n  j.finished_at,\n  (EXTRACT(EPOCH FROM COALESCE(jr.created_at, j.created_at)) * 1000)::bigint - 300000 AS log_window_from_ms,\n  (EXTRACT(EPOCH FROM j.finished_at) * 1000)::bigint + 300000 AS log_window_to_ms,\n  EXTRACT(EPOCH FROM (j.finished_at - COALESCE(jr.created_at, j.created_at))) AS duration_seconds,\n  COALESCE(jp.files_completed, 0) AS files_completed,\n  COALESCE(jp.total_files, 0) AS total_files\nFROM jobs j\nLEFT JOIN LATERAL (\n  SELECT * FROM job_reservations jr2\n   WHERE jr2.job_id = j.id\n   ORDER BY jr2.created_at DESC\n   LIMIT 1\n) jr ON TRUE\nLEFT JOIN job_progress jp ON jp.job_id = j.id\nWHERE j.job_type IN ('from-scratch-index','incremental-index')\n  AND j.finished_at IS NOT NULL\n  AND COALESCE(j.args->>'realmURL', '') = ${realm_url:sqlstring}\nORDER BY j.finished_at DESC\nLIMIT 100;",
            "refId": "A"
          }
        ],
