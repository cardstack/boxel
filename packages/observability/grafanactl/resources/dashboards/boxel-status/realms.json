            "rawSql": "SELECT\n  url,\n  error_doc->>'message' AS error_message,\n  to_timestamp(indexed_at / 1000.0) AS indexed_at\nFROM boxel_index\nWHERE realm_url = ${realm_url:sqlstring}\n  AND type = 'error'\n  AND is_deleted IS NOT TRUE\nORDER BY indexed_at DESC\nLIMIT 200;",
