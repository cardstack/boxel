            "format": "table",
            "rawQuery": true,
            "rawSql": "SELECT \n  username,\n  read,\n  write,\n  realm_owner,\n  CASE\n    WHEN realm_owner THEN 'owner'\n    WHEN write THEN 'read/write'\n    WHEN read THEN 'read'\n    ELSE 'none'\n  END AS permission\nFROM realm_user_permissions\nWHERE realm_url = ${realm_url:sqlstring}\nORDER BY realm_owner DESC, write DESC, read DESC, username ASC\nLIMIT 500;",
