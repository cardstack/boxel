            "editorMode": "code",
            "format": "table",
            "rawQuery": true,
            "rawSql": "SELECT \n    u.matrix_user_id,\n    SUM(CASE WHEN c.credit_type = 'plan_allowance' AND s.status = 'active' THEN c.credit_amount ELSE 0 END) as total_plan_allowance,\n    ABS(SUM(CASE WHEN c.credit_type = 'plan_allowance_used' AND s.status = 'active' THEN c.credit_amount ELSE 0 END)) as total_plan_allowance_used,\n    SUM(CASE WHEN c.credit_type = 'plan_allowance' AND s.status = 'active' THEN c.credit_amount ELSE 0 END) + \n    SUM(CASE WHEN c.credit_type = 'plan_allowance_used' AND s.status = 'active' THEN c.credit_amount ELSE 0 END) as remaining_plan_allowance,\n    SUM(CASE WHEN c.credit_type = 'extra_credit' THEN c.credit_amount ELSE 0 END) as total_extra_credit,\n    ABS(SUM(CASE WHEN c.credit_type = 'extra_credit_used' THEN c.credit_amount ELSE 0 END)) as total_extra_credit_used,\n    SUM(CASE WHEN c.credit_type = 'extra_credit' THEN c.credit_amount ELSE 0 END) + \n    SUM(CASE WHEN c.credit_type = 'extra_credit_used' THEN c.credit_amount ELSE 0 END) as remaining_extra_credit\nFROM users u\nLEFT JOIN credits_ledger c ON c.user_id = u.id\nLEFT JOIN subscription_cycles sc ON sc.id = c.subscription_cycle_id\nLEFT JOIN subscriptions s ON s.id = sc.subscription_id\nWHERE u.matrix_user_id = '${matrix_user_id}'\n    AND (c.credit_type IN ('plan_allowance', 'plan_allowance_used', 'extra_credit', 'extra_credit_used') OR c.credit_type IS NULL)\nGROUP BY u.matrix_user_id;",
            "refId": "A",
