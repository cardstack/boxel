            "editorMode": "code",
            "format": "table",
            "rawQuery": true,
            "rawSql": "SELECT s.relname AS \"Table\", pg_size_pretty(pg_total_relation_size(c.oid)) AS \"Size\", pg_total_relation_size(c.oid) AS \"_bytes\", n_live_tup AS \"Live rows\", n_dead_tup AS \"Dead rows\", CASE WHEN n_live_tup > 0 THEN ROUND(100.0 * n_dead_tup / n_live_tup, 1) END AS \"Dead %\", GREATEST(last_autovacuum, last_vacuum) AS \"Last vacuum\", GREATEST(last_autoanalyze, last_analyze) AS \"Last analyze\" FROM pg_stat_user_tables s JOIN pg_class c ON c.oid = s.relid AND c.relkind = 'r' ORDER BY pg_total_relation_size(c.oid) DESC LIMIT 20;",
            "refId": "A"
          }
        ],
