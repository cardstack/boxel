# Build output
dist/

# Vendored type sources for `boxel parse` outside the monorepo
# (CS-11165). Populated by `pnpm build:types` from sibling packages
# at release time. Committed-via-publish, never in git.
bundled-types/

# Vendored host test harness for `boxel test` outside the monorepo
# (CS-11164). Populated by `pnpm build:test-harness` from
# `packages/host/dist/` at release time. Shipped via the `files`
# array in package.json; never in git.
bundled-test-harness/

# Vendored base + skills realm sources served by the CLI's local
# module server for `boxel test` (CS-11164). Populated by
# `pnpm build:realms` from sibling packages at release time.
# Shipped via the `files` array in package.json; never in git.
bundled-realms/

# Cached shallow clone of cardstack/boxel-skills used by scripts/build-skills.ts
.boxel-skills-cache/

